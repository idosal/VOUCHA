{
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json",
  "name": "clawptcha-flue-investigator",
  "workers_dev": false,
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI" },
  "exports": {
    "FlueInvestigatePrWorkflow": {
      "type": "durable-object",
      "storage": "sqlite"
    },
    "FlueRegistry": {
      "type": "durable-object",
      "storage": "sqlite"
    }
  }
}
