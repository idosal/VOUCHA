{
  "name": "@clawptcha/flue-investigator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "flue build --target cloudflare && node scripts/patch-wrangler.mjs",
    "check": "tsc --noEmit",
