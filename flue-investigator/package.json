    "dev": "flue dev --target cloudflare"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.1",
    "agents": "^0.14.1",
    "hono": "^4.6.0",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@flue/cli": "1.0.0-beta.1",
    "typescript": "^5.7.0",
    "wrangler": "^4.107.0"
  }
}
